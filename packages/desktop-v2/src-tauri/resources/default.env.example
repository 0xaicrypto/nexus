# ══════════════════════════════════════════════════════════════════════
# Nexus default environment — TEMPLATE (committed)
#
# The real default.env is AUTO-GENERATED by scripts/build-macos.sh from
# packages/server/.env and is NOT committed (contains live credentials).
# Copy this file to default.env for a manual/dev tauri build.
#
# Tauri's lib.rs::seed_or_merge_user_env reads default.env on launch and
# delta-merges into ~/Library/Application Support/RuneProtocol/.env.
# ══════════════════════════════════════════════════════════════════════

# ── Authentication ───────────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Rune Protocol
WEBAUTHN_ORIGIN=http://localhost:3000
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── LLM Gateway ─────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Tool Execution ───────────────────────────────────────────────────
TAVILY_API_KEY=
# JINA_API_KEY=

# ── Chain Proxy ──────────────────────────────────────────────────────
CHAIN_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
CHAIN_AGENT_CONTRACT_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_LLM_REQUESTS_PER_MINUTE=60
RATE_LIMIT_OTHER_REQUESTS_PER_MINUTE=120

# ── Hosted email relay ───────────────────────────────────────────────
# Injected at build time by scripts/build-macos.sh — never commit the key.
NEXUS_RELAY_URL=https://nexus-email-relay.fly.dev
NEXUS_RELAY_API_KEY=

