{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus",
  "version": "0.1.15",
  "identifier": "io.runeprotocol.nexus",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexus",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#1B1A18"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http://localhost:8001 asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' http://localhost:8001 ws://localhost:8001 ipc: http://ipc.localhost; media-src 'self' blob: http://localhost:8001; frame-src http://localhost:8001; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Medical",
    "shortDescription": "Clinical workflow agent",
    "longDescription": "Nexus is a clinical workflow agent for radiologists and hospitalists. Imaging, labs, and chat in one surface.",
    "externalBin": [
      "binaries/nexus-server"
    ],
    "resources": [
      "resources/default.env",
      "resources/server.build_info"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "exceptionDomain": "localhost",
      "providerShortName": "Nexus",
      "entitlements": "entitlements.plist"
    }
  }
}
